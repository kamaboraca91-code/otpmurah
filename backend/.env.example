MYPG_API_KEY=
MYPG_MERCHANT_ID=
MYPG_CALLBACK_SECRET=
MYPG_CALLBACK_URL=https://my-api.onrender.com/webhooks/mypg

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
